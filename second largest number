#include <iostream>
#include <climits> 
using namespace std;
int main() {
    int a[] = {17, 45, 23, 89, 100, 4, 45};
    int n = sizeof(a) / sizeof(a[0]); 
    int max1 = INT_MIN;
    int max2 = INT_MIN;
    for (int i = 0; i < n; i++) {
        if (a[i] > max1) {
            max2 = max1; 
            max1 = a[i];  
        }
        else if (a[i] > max2 && a[i] != max1) {
            max2 = a[i];  
        }
    }
    cout << "Output: " << max2 << endl;
    return 0;
}

