import java.util.Scanner;
class Recharge {
    public Recharge(int amount) {
        System.out.println("Recharge Amount: " + amount);
    }
    public Recharge(int amount, int validity) {
        System.out.println("Recharge Amount: " + amount);
        System.out.println("Validity: " + validity + " Days");
    }
    public Recharge(int amount, int validity, String dataPack) {
        System.out.println("Recharge Amount: " + amount);
        System.out.println("Validity: " + validity + " Days");
        System.out.println("Data Pack: " + dataPack);
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int amt1 = scanner.nextInt();
            new Recharge(amt1);
        }
        if (scanner.hasNextInt()) {
            int amt2 = scanner.nextInt();
            int validity2 = scanner.nextInt();
            new Recharge(amt2, validity2);
        }
        if (scanner.hasNextInt()) {
            int amt3 = scanner.nextInt();
            int validity3 = scanner.nextInt();
            String dataPack3 = scanner.next();
            new Recharge(amt3, validity3, dataPack3);
        }
        scanner.close();
    }
}
