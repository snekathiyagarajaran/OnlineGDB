import java.util.Scanner;
class ShoppingSystem {
    public void purchase(String name) {
        System.out.println("Product: " + name);
    }
    public void purchase(String name, int quantity) {
        System.out.println("Product: " + name);
        System.out.println("Quantity: " + quantity);
    }
    public void purchase(String name, int quantity, String discountCode) {
        System.out.println("Product: " + name);
        System.out.println("Quantity: " + quantity);
        System.out.println("Discount Code: " + discountCode);
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        ShoppingSystem shop = new ShoppingSystem();
        if (scanner.hasNext()) {
            String name1 = scanner.next();
            shop.purchase(name1);
        }
        if (scanner.hasNext()) {
            String name2 = scanner.next();
            int quantity2 = scanner.nextInt();
            shop.purchase(name2, quantity2);
        }
        if (scanner.hasNext()) {
            String name3 = scanner.next();
            int quantity3 = scanner.nextInt();
            String code3 = scanner.next();
            shop.purchase(name3, quantity3, code3);
        }
        scanner.close();
    }
}
