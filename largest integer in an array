#include<stdio.h>
int main()
{
int a[10],n,i,j,t;
printf("Enter the no of elements in Array");
scanf("%d\n",&n);
 for(i=0;i<n;i++)
scanf("%d",&a[i]);
 for(i=0;i<n;i++)
{
for(j=0;j<n;j++)
{
if(a[i]>a[j])
{
t=a[i];
a[i]=a[j];
a[j]=t;
}
}
}
 printf("\nSorted Array");
for(i=0;i<n;i++)
printf("%d ",a[i]);
 printf("\nThe sum of Largst two number is (%d+%d=%d)",a[0],a[1],a[0]+a[1]);
return 0;
}
