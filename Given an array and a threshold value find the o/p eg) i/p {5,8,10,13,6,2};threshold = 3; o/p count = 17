#include <iostream>
using namespace std;
int main() {
    int arr[] = {5, 8, 10, 13, 6, 2};
    int threshold = 3;
    int n = sizeof(arr) / sizeof(arr[0]);
    int total_count = 0;
    for (int i = 0; i < n; i++) {
        total_count += (arr[i] + threshold - 1) / threshold;
    }
    cout << "Output count = " << total_count << endl;
    return 0;
}
